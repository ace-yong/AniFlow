{
  "name": "aniflow",
  "version": "2.0.0",
  "description": "游戏自动化调度工具",
  "author": "AniFlow Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.aniflow.app",
    "productName": "AniFlow",
    "directories": {
      "output": "aniflow-202607020110"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "../electron/dist/gui_server.exe",
        "to": "gui_server.exe"
      },
      {
        "from": "../electron/renderer",
        "to": "renderer"
      },
      {
        "from": "../wallpaper_source.jpg",
        "to": "wallpaper_source.jpg"
      }
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  }
}