{
  "name": "aniflow",
  "version": "1.1.0",
  "description": "游戏自动化调度工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.aniflow.app",
    "productName": "AniFlow",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "gui_server.py",
      "renderer/**/*",
      "src/**/*",
      "config/**/*"
    ],
    "extraResources": [
      {
        "from": "src",
        "to": "src"
      },
      {
        "from": "config",
        "to": "config"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
