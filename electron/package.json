{
  "name": "aniflow",
  "version": "1.1.0",
  "description": "游戏自动化调度工具",
  "author": "AniFlow Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.aniflow.app",
    "productName": "AniFlow",
    "directories": {
      "output": "aniflow-20260701234004"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      { "from": "../gui_server.py", "to": "gui_server.py" },
      { "from": "../electron/renderer", "to": "renderer" },
      { "from": "../src", "to": "src" },
      { "from": "../config", "to": "config" },
      { "from": "../wallpaper_source.jpg", "to": "wallpaper_source.jpg" }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0"
  }
}
